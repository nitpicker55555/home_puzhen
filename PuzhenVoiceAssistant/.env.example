# Copy this file to `.env` and fill in your key.  `.env` is git-ignored.
#   cp .env.example .env   &&   edit .env
AIHUBMIX_API_KEY=sk-your-aihubmix-key-here

# Optional overrides:
# ASSISTANT_MODEL=gpt-4.1-nano       # gemini-2.5-flash / gpt-4o-mini / qwen-turbo ...
# ASSISTANT_LOCALE=zh-CN             # en-US if you speak mostly English
# AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# 语音原生对话（默认开启）:
# ASSISTANT_CHAT=audio               # audio=你的原声直达模型,原生语音回答; text=旧管线(STT→LLM→TTS)
# ASSISTANT_AUDIO_MODEL=gpt-audio-1.5
# ASSISTANT_AUDIO_VOICE=marin        # marin / cedar / coral / sage ...
# ASSISTANT_TOOLS=on                 # on=允许执行bash查本地数据(活动记录等); off=禁用
# RECORDS_FILE=/Users/puzhen/PycharmProjects/record_me/app_switch.log
# RECORDS_AIR_FILE=/Users/puzhen/PycharmProjects/record_me/app_switch_air.log
# ASSISTANT_CODEX=on                 # on=复杂问题交给本地Codex智能体研究; off=禁用
# CODEX_BIN=/opt/homebrew/bin/codex
# ASSISTANT_MODE=simple              # 默认模式 simple(只用gpt) / thinking(可调用Codex),界面里可随时切

# 智能家居(Home Assistant):
# HA_URL=http://localhost:8123
# HA_TOKEN=                          # 在 HA 里创建的长期访问令牌,填了才能控制家里的灯/空调等
# ASSISTANT_REPLY_RATE=1.0           # 回答语音播放速率(0.9=更慢,保音高),语速主要靠提示词控制

# Text-to-speech (text 模式与开场白使用):
# ASSISTANT_TTS=api                  # api = OpenAI 人声（自然，~1分钱/句）; system = 系统自带（免费离线）
# ASSISTANT_TTS_MODEL=gpt-4o-mini-tts
# ASSISTANT_TTS_VOICE=nova           # nova / coral / sage / shimmer / alloy / ash / onyx / echo
# ASSISTANT_TTS_INSTRUCTIONS=说话自然亲切，口语化
# ASSISTANT_RATE=1.0                 # 语速倍率
# ASSISTANT_VOICE=                   # 系统声音语言强制，如 zh-CN（仅 system 模式）
